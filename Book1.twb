      <aliases enabled='yes' />
      <column caption='Profit Ratio' datatype='real' name='[Calculation_1368249927221915648]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_4242197621460993]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) / COUNT([Order ID])' />
      </column>
      <column caption=' Customer LTV' datatype='real' name='[Calculation_4242197622030338]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Customer Name] :  SUM([Sales])}' />
      </column>
      <column caption='Profit Margin %' datatype='real' name='[Calculation_4242197630042115]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales]) * 100' />
      </column>
